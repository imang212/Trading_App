<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <application
        android:name="com.trading.trading_app.TradingApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_signals"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_signals"
        android:supportsRtl="true"
        android:theme="@style/Theme.TradingApp"
        android:hardwareAccelerated="true"
        android:largeHeap="true">
        <activity
            android:name="com.trading.trading_app.ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.trading.trading_app.ui.SettingsActivity"
            android:exported="false"
            android:parentActivityName="com.trading.trading_app.ui.MainActivity" />
        <!-- WorkManager background refresh -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>