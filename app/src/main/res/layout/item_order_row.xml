<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_ord_asset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_ord_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_blue"
            android:textSize="10sp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_ord_signal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"/>

    <TextView
        android:id="@+id/tv_ord_buy_limit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textColor="@color/buy_green"
        android:textSize="10sp"
        android:gravity="end"/>

    <TextView
        android:id="@+id/tv_ord_stop_loss"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textColor="@color/sell_red"
        android:textSize="10sp"
        android:gravity="end"/>

    <TextView
        android:id="@+id/tv_ord_tp1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textColor="@color/accent_blue"
        android:textSize="10sp"
        android:gravity="end"/>

    <TextView
        android:id="@+id/tv_ord_tp2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textColor="@color/accent_purple"
        android:textSize="10sp"
        android:gravity="end"/>

    <TextView
        android:id="@+id/tv_ord_risk"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/neu_yellow"
        android:textSize="10sp"
        android:gravity="end"/>

    <!-- hidden price field used in adapter -->
    <TextView
        android:id="@+id/tv_ord_price"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

</LinearLayout>
