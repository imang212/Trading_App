<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:paddingBottom="80dp"
    android:clipToPadding="false">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">
        <!-- Asset selector + Run button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <!-- Asset spinner label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/backtest_asset"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <!-- Asset spinner — light bg so text is visible -->
                <Spinner
                    android:id="@+id/spinner_backtest_asset"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@color/bg_spinner"
                    android:backgroundTint="@color/accent_blue"
                    android:popupBackground="@color/bg_spinner_dropdown"/>
                <!-- Capital input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Initial Capital (USD)"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxStrokeColor="@color/accent_blue"
                    app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_backtest_capital"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="10000"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:padding="10dp"/>
                </com.google.android.material.textfield.TextInputLayout>
                <!-- Start date picker -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Backtest Start Date"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_backtest_pick_date"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Pick Start Date"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/accent_blue"
                        app:strokeWidth="1dp"
                        app:backgroundTint="@color/bg_card2"/>
                    <TextView
                        android:id="@+id/tv_backtest_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="5-year default"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        android:gravity="start"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_run_backtest"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:text="▶ Run Backtest"
                    app:backgroundTint="@color/accent_blue"/>
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_backtest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    android:indeterminate="true"
                    app:indicatorColor="@color/accent_blue"/>
                <TextView
                    android:id="@+id/tv_backtest_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/sell_red"
                    android:textSize="12sp"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!-- Results card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_backtest_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:id="@+id/tv_bt_asset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tv_bt_alpha_badge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Final Value" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_bt_final" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Return" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_bt_return" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B&amp;H Return" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_bt_bh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="15sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Alpha" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_bt_alpha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Win Rate" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_bt_win_rate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/buy_green" android:textSize="15sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sharpe" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_bt_sharpe" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Max DD" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_bt_max_dd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/sell_red" android:textSize="15sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trades" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_bt_trades" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!-- Equity chart -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/equity_chart"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginBottom="24dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>