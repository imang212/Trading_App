    <View android:layout_width="140dp" android:layout_height="16dp" android:background="@color/shimmer_bg" android:layout_marginBottom="8dp"/>
    <View android:layout_width="80dp"  android:layout_height="12dp" android:background="@color/shimmer_bg" android:layout_marginBottom="12dp"/>
    <View android:layout_width="match_parent" android:layout_height="8dp"  android:background="@color/shimmer_bg" android:layout_marginBottom="8dp"/>
    <View android:layout_width="match_parent" android:layout_height="8dp"  android:background="@color/shimmer_bg" android:layout_marginBottom="8dp"/>
    <View android:layout_width="200dp" android:layout_height="8dp"  android:background="@color/shimmer_bg"/>

</LinearLayout>
